{
  "name": "oticas-tiago-meta-agent",
  "version": "1.0.0",
  "description": "Agente para Meta Ads + Google Sheets das Óticas do Tiago: dashboard, alertas, análise de campanhas/conjuntos/criativos e automações seguras.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js run --client all",
    "sync": "node src/index.js sync --client all",
    "dashboard": "node src/index.js dashboard --client all",
    "analyze": "node src/index.js analyze --client all",
    "alerts": "node src/index.js alerts --client all",
    "validate": "node src/index.js validate",
    "dry": "node src/index.js run --client all --dry-run",
    "otica1": "node src/index.js run --client otica1",
    "otica2": "node src/index.js run --client otica2",
    "scheduler": "node scheduler.js",
    "check": "node --check src/index.js && node --check scheduler.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "meta-ads",
    "google-sheets",
    "dashboard",
    "leads",
    "cpl",
    "roi"
  ],
  "license": "MIT"
}
