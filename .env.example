# =====================================================================
# DL Operational System — variáveis de ambiente (exemplo)
# Copie para .env.local. O app funciona SEM elas no MVP (modo mock).
# =====================================================================

# Supabase (Fase 2) — quando ausentes, o app roda em modo mock.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Apenas server-side. Necessaria para convidar usuarios (Configuracoes).
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (Fase 4 — DLtinho). Nunca expor no client. Usar apenas server-side.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Meta Ads (app/api/meta/ad-accounts/link e app/api/meta/insights) — sem isso a
# rota responde 400 explicando o que falta. SUPABASE_SERVICE_ROLE_KEY acima e
# usada por ad-accounts/link para gravar o ad_account_id validado (nunca o
# cliente) — insights so aceita o id interno do vinculo, nao o id do Meta.
META_ACCESS_TOKEN=
META_API_VERSION=v19.0

# Google Sheets via service account (app/api/sheets/create e app/api/sheets/export)
# — JSON da service account do Google Cloud Console; GOOGLE_PRIVATE_KEY mantém os \n
# literais (não quebra de linha real). SUPABASE_SERVICE_ROLE_KEY acima é usada por
# sheets/create para gravar o external_id retornado pelo Google (nunca o cliente).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Integrações futuras (Fase 5) — apenas placeholders, não usadas no MVP.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WHATSAPP_PROVIDER_URL=
TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_BOARD_ID=
