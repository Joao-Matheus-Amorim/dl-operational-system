# =============================================================================
# Óticas do Tiago — Meta Ads + Google Sheets Agent
# Copie para .env e preencha os valores reais.
# =============================================================================

# Meta Ads API
META_ACCESS_TOKEN=EAAXxxxxxxxxxxxxxxxxxxxxxxxx
META_API_VERSION=v19.0

# Google Sheets — Service Account
# A planilha precisa estar compartilhada com este e-mail como Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=seu-service-account@seu-projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCOLE_A_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# Planilha compartilhada enviada no chat:
# https://docs.google.com/spreadsheets/d/1xglEDDEf7ZIwx_dFnHuL_i9ZPC15vpXAz9Tlscsz3V0/edit
SPREADSHEET_ID_TIAGO=1xglEDDEf7ZIwx_dFnHuL_i9ZPC15vpXAz9Tlscsz3V0

# Clientes / Unidades
OTICA1_NAME=Ótica 1
OTICA1_AD_ACCOUNT_ID=act_PREENCHER_OTICA_1
OTICA1_TAB_PREFIX=Ótica 1
OTICA1_LEAD_VALUE=0
OTICA1_MONTHLY_GOAL_LEADS=100
OTICA1_MONTHLY_GOAL_SPEND=1500

OTICA2_NAME=Ótica 2
OTICA2_AD_ACCOUNT_ID=act_PREENCHER_OTICA_2
OTICA2_TAB_PREFIX=Ótica 2
OTICA2_LEAD_VALUE=0
OTICA2_MONTHLY_GOAL_LEADS=100
OTICA2_MONTHLY_GOAL_SPEND=1500

# Alertas e regras
ALERT_BALANCE_MIN_BRL=50
ALERT_CPL_MAX_BRL=30
MIN_SPEND_TO_EVALUATE_BRL=20
MAX_SPEND_WITHOUT_LEAD_BRL=40
MIN_IMPRESSIONS_TO_EVALUATE=500
MIN_CTR_GOOD=1.0
MIN_LEADS_FOR_WINNER=5
GOOD_CPL_BRL=20

# Automação segura
# notify: apenas alerta | auto_pause: pausa anúncios ruins | dry_run: simula
ACTION_MODE=notify
AUTO_PAUSE_ENABLED=false
CREATE_TEST_CAMPAIGN_ENABLED=false
TEST_CAMPAIGN_DAILY_BUDGET_CENTS=3000

# WhatsApp via Z-API opcional. Sem isso, os alertas ficam no console/log.
WHATSAPP_PROVIDER=none
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
WHATSAPP_TO=5521999999999

# Agendamento
TIMEZONE=America/Sao_Paulo
CRON_DAILY_SYNC=0 23 * * *
CRON_ALERTS=0 8,14 * * *
CRON_ANALYZE=0 9 * * 1-6
